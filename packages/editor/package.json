{
  "name": "@gedatou/editor",
  "version": "0.3.0",
  "description": "Embeddable Remotion video editor React components — timeline, canvas, inspector; shadcn-authored, theme-able",
  "keywords": [
    "remotion",
    "video-editor",
    "react",
    "timeline",
    "shadcn",
    "tailwind"
  ],
  "homepage": "https://github.com/GGGLHHH/Remotion-demo#readme",
  "bugs": {
    "url": "https://github.com/GGGLHHH/Remotion-demo/issues"
  },
  "license": "MIT",
  "author": "ge Datou (https://github.com/GGGLHHH)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GGGLHHH/Remotion-demo.git",
    "directory": "packages/editor"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "src/styles.css",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./adapters": "./src/lib/adapters/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./adapters": {
        "types": "./dist/adapters.d.ts",
        "import": "./dist/adapters.js"
      },
      "./styles.css": "./src/styles.css"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@base-ui/react": "^1.6.0",
    "lucide-react": "^1.25.0",
    "zustand": "^5.0.0",
    "mediabunny": "^1.50.0",
    "remotion": "4.0.491",
    "@remotion/player": "4.0.491",
    "@remotion/media": "4.0.491",
    "@remotion/gif": "4.0.491",
    "@remotion/google-fonts": "4.0.491",
    "@remotion/captions": "4.0.491"
  },
  "dependencies": {
    "@gedatou/shared": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.6.0",
    "@remotion/captions": "4.0.491",
    "@remotion/gif": "4.0.491",
    "@remotion/google-fonts": "4.0.491",
    "@remotion/media": "4.0.491",
    "@remotion/player": "4.0.491",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "lucide-react": "^1.25.0",
    "mediabunny": "^1.50.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remotion": "4.0.491",
    "tsup": "^8.5.0",
    "typescript": "~6.0.2",
    "vitest": "^3.2.7",
    "zustand": "^5.0.14"
  }
}
