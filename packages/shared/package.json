{
  "name": "@gedatou/shared",
  "version": "0.2.0",
  "description": "Shared data model and Remotion composition for the @gedatou/editor video editor",
  "keywords": [
    "remotion",
    "video-editor",
    "composition"
  ],
  "homepage": "https://github.com/GGGLHHH/Remotion-demo#readme",
  "bugs": {
    "url": "https://github.com/GGGLHHH/Remotion-demo/issues"
  },
  "license": "MIT",
  "author": "ge Datou (https://github.com/GGGLHHH)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GGGLHHH/Remotion-demo.git",
    "directory": "packages/shared"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./composition": "./src/composition/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./composition": {
        "types": "./dist/composition.d.ts",
        "import": "./dist/composition.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "remotion": "4.0.491",
    "@remotion/captions": "4.0.491",
    "@remotion/gif": "4.0.491",
    "@remotion/google-fonts": "4.0.491",
    "@remotion/media": "4.0.491"
  },
  "devDependencies": {
    "@remotion/captions": "4.0.491",
    "@remotion/gif": "4.0.491",
    "@remotion/google-fonts": "4.0.491",
    "@remotion/media": "4.0.491",
    "@types/react": "^19.2.0",
    "react": "^19.2.0",
    "remotion": "4.0.491",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
